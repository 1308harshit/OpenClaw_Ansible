# HTTPS Server Configuration for timlam007.com
# Generated by Ansible for SSL Certificate Demo

server {
    listen 443 ssl http2;
    server_name snoopy.timlam007.com www.snoopy.timlam007.com;

    # SSL Certificate Configuration
    # Use a full chain so clients can validate the intermediate/issuing CA.
    ssl_certificate /etc/nginx/ssl/fullchain.crt;
    ssl_certificate_key /etc/nginx/ssl/server.key;

    # SSL Security Settings
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384';
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    # Security Headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # Access and Error Logs
    access_log /var/log/nginx/timlam007_access.log;
    error_log /var/log/nginx/timlam007_error.log;

    # Nginx health endpoint (does not depend on Node.js)
    location = /health {
        access_log off;
        default_type text/plain;
        return 200 "OK\n";
    }

    # Download the Vault Root CA (so you can add it to your laptop trust store)
    # After trusting this CA, Chrome will stop showing "Not secure" for this demo.
    location = /vault-root-ca.crt {
        default_type application/x-x509-ca-cert;
        add_header Content-Disposition 'attachment; filename="vault_root_ca.crt"' always;
        # Copied here by playbooks with world-readable permissions.
        alias /var/www/snoopy_timlam007/vault_root_ca.crt;
    }

    # Vault UI (served by Vault on localhost:8200)
    # Entry point for demo: https://snoopy.timlam007.com/vault-ui/
    # NOTE: Vault UI natively lives at /ui/ and uses /v1/ for API calls.
    location = /vault-ui {
        return 301 /vault-ui/;
    }

    location = /vault-ui/ {
        return 302 /ui/;
    }

    # Proxy Vault UI assets/pages
    location ^~ /ui/ {
        proxy_pass http://127.0.0.1:8200/ui/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_connect_timeout 75s;
        proxy_buffering off;
    }

    # Proxy Vault API (required for Vault UI to function)
    location ^~ /v1/ {
        proxy_pass http://127.0.0.1:8200/v1/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_connect_timeout 75s;
        proxy_buffering off;
    }

    # Reverse proxy to Node.js frontend on port 8000
    location / {
        proxy_pass http://localhost:8000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 300s;
        proxy_connect_timeout 75s;
    }

    # All other requests proxied to Node.js frontend
    # Frontend handles /reports/*, health checks, and all UI routes
}

# HTTP to HTTPS Redirect (with exception for Root CA download)
server {
    listen 80;
    server_name snoopy.timlam007.com www.snoopy.timlam007.com;

    # Exception: Serve Root CA over HTTP (so users can download it before trusting the CA)
    # This solves the chicken-and-egg problem: you need the CA to trust HTTPS, but can't download it over HTTPS.
    location = /vault-root-ca.crt {
        default_type application/x-x509-ca-cert;
        add_header Content-Disposition 'attachment; filename="vault_root_ca.crt"' always;
        alias /var/www/snoopy_timlam007/vault_root_ca.crt;
    }

    # Redirect all other HTTP traffic to HTTPS
    return 301 https://$server_name$request_uri;
}
